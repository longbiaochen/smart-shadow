#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"

mkdir -p .build/swiftpm-cache .build/module-cache
export CLANG_MODULE_CACHE_PATH="$PWD/.build/module-cache"

swift build \
  --scratch-path "$PWD/.build" \
  --cache-path "$PWD/.build/swiftpm-cache" \
  --manifest-cache local
bash tests/source_enable_requires_ok_acceptance.sh
bash tests/apple_reminders_inbox_acceptance_supported.sh
bash tests/apple_reminders_inbox_requires_authorization.sh
bash tests/apple_reminders_inbox_enable_requires_authorization.sh
bash tests/reminders_quadrant_plan_requires_dry_run.sh
bash tests/reminders_db_doctor_readonly.sh
bash tests/apple_mail_summary_demo_processes_review.sh
bash tests/project_mail_decision_cli.sh
bash tests/github_issue_workflow_cli.sh
bash tests/shadowd_github_issue_swift.sh
bash tests/lark_calendar_events_structured_acceptance.sh
bash tests/lark_calendar_events_duplicate_refreshes_projection.sh
bash tests/lark_calendar_events_named_calendar_acceptance.sh
bash tests/lark_tasks_structured_acceptance.sh
bash tests/lark_source_doctor_reports_cli_blocker.sh
bash tests/google_sources_structured_acceptance.sh
bash tests/google_source_doctor_reports_auth_blockers.sh
bash tests/google_calendar_dry_run_resets_expired_cursor.sh
bash tests/source_doctor_reports_readiness.sh
bash tests/service_status_reports_runtime.sh
bash tests/service_status_reports_freshness.sh
bash tests/service_status_marks_error_report.sh
bash tests/service_status_marks_missing_audit_report.sh
bash tests/service_status_marks_stale_last_run.sh
bash tests/service_status_reports_attention.sh
bash tests/service_status_attention_suggests_actions.sh

#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT_DIR"

export SMART_SHADOW_CONFIG="${SMART_SHADOW_CONFIG:-$ROOT_DIR/config/smart-shadow.yaml}"
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/longbiao/.npm-global/bin:$PATH"

mkdir -p "$ROOT_DIR/var/logs" "$ROOT_DIR/.smart-shadow"

if [[ ! -x "$ROOT_DIR/node_modules/.bin/tsx" ]]; then
  echo "missing node_modules/.bin/tsx; run pnpm install in $ROOT_DIR" >&2
  exit 78
fi

exec "$ROOT_DIR/node_modules/.bin/tsx" "$ROOT_DIR/src/index.ts"

#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LABEL="me.longbiaochen.shadowd"
OLD_LABEL="me.longbiaochen.smart-shadowd"
DOMAIN="gui/$(id -u)"
PLIST_DEST="$HOME/Library/LaunchAgents/$LABEL.plist"
OLD_PLIST_DEST="$HOME/Library/LaunchAgents/$OLD_LABEL.plist"
TEMPLATE="$ROOT_DIR/launchd/$LABEL.plist.template"
DEFAULT_CONFIG="$ROOT_DIR/config/smart-shadow.example.json"

usage() {
  cat <<'EOF'
Usage: bin/shadowd <command>

Commands:
  once [--dry-run] [--fixture PATH]       Reconcile the Life OS GitHub Project once
  run                                     Run the Swift GitHub Project reconciler loop
  github-issue --payload PATH             Handle one GitHub issue event payload
  inspect-issue [--issue N] [--fixture P] Inspect one Project issue plan
  render-plist [--stdout]                 Render the LaunchAgent plist
  install                                 Install and bootstrap the user LaunchAgent
  uninstall                               Boot out and remove the user LaunchAgent
  start                                   Start the LaunchAgent
  stop                                    Stop the LaunchAgent
  restart                                 Restart the LaunchAgent
  status                                  Show launchctl status and recent logs
  logs                                    Tail shadowd logs
EOF
}

shadowd_config() {
  if [[ -n "${SMART_SHADOW_CONFIG:-}" && "${SMART_SHADOW_CONFIG##*.}" == "json" ]]; then
    printf '%s\n' "$SMART_SHADOW_CONFIG"
  elif [[ -f "$ROOT_DIR/config/smart-shadow.json" ]]; then
    printf '%s\n' "$ROOT_DIR/config/smart-shadow.json"
  else
    printf '%s\n' "$DEFAULT_CONFIG"
  fi
}

ensure_core() {
  swift build --package-path "$ROOT_DIR" --product shadowd >/dev/null
}

run_core() {
  ensure_core
  exec "$ROOT_DIR/.build/debug/shadowd" --config "$(shadowd_config)" "$@"
}

render_plist() {
  sed "s#__PROJECT_ROOT__#$ROOT_DIR#g" "$TEMPLATE"
}

install_agent() {
  mkdir -p "$(dirname "$PLIST_DEST")" "$ROOT_DIR/var/logs"
  render_plist > "$PLIST_DEST"
  plutil -lint "$PLIST_DEST"
  launchctl bootout "$DOMAIN" "$OLD_PLIST_DEST" >/dev/null 2>&1 || true
  rm -f "$OLD_PLIST_DEST"
  launchctl bootout "$DOMAIN" "$PLIST_DEST" >/dev/null 2>&1 || true
  launchctl bootstrap "$DOMAIN" "$PLIST_DEST"
  launchctl enable "$DOMAIN/$LABEL" >/dev/null 2>&1 || true
  launchctl kickstart -k "$DOMAIN/$LABEL"
  printf 'installed %s\n%s\n' "$LABEL" "$PLIST_DEST"
}

uninstall_agent() {
  launchctl bootout "$DOMAIN" "$PLIST_DEST" >/dev/null 2>&1 || true
  rm -f "$PLIST_DEST"
  printf 'uninstalled %s\n' "$LABEL"
}

status_agent() {
  printf 'label: %s\nplist: %s\n' "$LABEL" "$PLIST_DEST"
  if ! launchctl print "$DOMAIN/$LABEL"; then
    printf 'not loaded\n'
    return 1
  fi
  tail_log "$ROOT_DIR/var/logs/shadowd.out.log" stdout 20
  tail_log "$ROOT_DIR/var/logs/shadowd.err.log" stderr 40
}

tail_log() {
  local path="$1" label="$2" lines="$3"
  printf '\n%s: %s\n' "$label" "$path"
  [[ -f "$path" ]] && tail -n "$lines" "$path"
}

command="${1:-}"
shift || true

case "$command" in
  ""|-h|--help|help) usage ;;
  once|run|github-issue|inspect-issue) run_core "$command" "$@" ;;
  render-plist)
    if [[ "$#" -gt 0 && "$*" != "--stdout" ]]; then
      usage
      exit 2
    fi
    render_plist
    ;;
  install) install_agent ;;
  uninstall) uninstall_agent ;;
  start) launchctl kickstart -k "$DOMAIN/$LABEL" ;;
  stop) launchctl kill TERM "$DOMAIN/$LABEL" >/dev/null 2>&1 || true ;;
  restart)
    launchctl kill TERM "$DOMAIN/$LABEL" >/dev/null 2>&1 || true
    sleep 1
    launchctl kickstart -k "$DOMAIN/$LABEL"
    ;;
  status) status_agent ;;
  logs)
    mkdir -p "$ROOT_DIR/var/logs"
    tail -n 80 -f "$ROOT_DIR/var/logs/shadowd.out.log" "$ROOT_DIR/var/logs/shadowd.err.log"
    ;;
  *)
    usage
    exit 2
    ;;
esac

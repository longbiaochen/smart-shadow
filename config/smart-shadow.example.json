{
  "runtime_root": "var",
  "rules_file": "config/rules.json",
  "google": {
    "oauth_client_id": "",
    "oauth_scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/tasks.readonly",
      "https://www.googleapis.com/auth/contacts.readonly"
    ]
  },
  "poll_seconds": 10,
  "github": {
    "enabled": true,
    "agentName": "shadow",
    "daemonName": "shadowd",
    "assignee": "shadow",
    "allowedCommentCommands": [
      "@shadow",
      "@shadow fix",
      "@shadow continue",
      "@shadow test",
      "@shadow explain"
    ],
    "events": [
      "issues",
      "issue_comment"
    ],
    "repos": {
      "longbiaochen/smart-shadow": {
        "localPath": "/Users/longbiao/Projects/smart-shadow",
        "defaultBase": "main",
        "allowedSenders": [
          "longbiaochen"
        ],
        "testCommand": "bin/smart-shadow-test",
        "codexSandbox": "workspace-write"
      }
    }
  },
  "sources": {
    "event_inbox": "inbox/events",
    "file_metadata": {
      "enabled": false,
      "paths": [
        "~/Downloads",
        "~/Desktop"
      ],
      "max_age_hours": 24,
      "max_items": 25,
      "timeout_seconds": 5,
      "ignore_names": [
        ".DS_Store"
      ]
    },
    "lark_daily_context": {
      "enabled": false,
      "commands": [
        {
          "label": "calendar_agenda",
          "argv": [
            "lark-cli",
            "calendar",
            "+agenda"
          ]
        },
        {
          "label": "my_tasks",
          "argv": [
            "lark-cli",
            "task",
            "+get-my-tasks"
          ]
        }
      ],
      "timeout_seconds": 20,
      "max_items_per_command": 20,
      "max_body_chars": 4000
    },
    "lark_calendar_events": {
      "enabled": false,
      "argv": [
        "lark-cli",
        "calendar",
        "+agenda",
        "--as",
        "user",
        "--format",
        "json"
      ],
      "timeout_seconds": 20,
      "window_past_days": 1,
      "window_future_days": 7,
      "chunk_days": 7,
      "max_items": 100,
      "primary_calendar_summary": "陈龙彪",
      "source_calendar_domains": {
        "陈龙彪": "work",
        "应酬": "relationship"
      },
      "extra_calendar_summaries": [
        "应酬"
      ]
    },
    "lark_tasks": {
      "enabled": false,
      "argv": [
        "lark-cli",
        "task",
        "+get-my-tasks",
        "--as",
        "user",
        "--complete=false",
        "--page-all",
        "--format",
        "json"
      ],
      "timeout_seconds": 20,
      "max_items": 100
    },
    "google_calendar_events": {
      "enabled": false,
      "calendar_ids": [
        "primary"
      ],
      "time_min": "2026-06-01T00:00:00+08:00",
      "time_max": "2026-07-31T23:59:59+08:00",
      "page_size": 250,
      "max_items": 100,
      "apple_calendar_names": {
        "primary": "Google - Primary"
      }
    },
    "google_tasks": {
      "enabled": false,
      "task_list_ids": [],
      "page_size": 100,
      "max_items": 100
    },
    "google_contacts": {
      "enabled": false,
      "page_size": 100,
      "max_items": 100,
      "person_fields": "names,emailAddresses,phoneNumbers,organizations,birthdays,addresses,metadata"
    },
    "chrome_bookmarks": {
      "enabled": false,
      "bookmarks_file": "~/Library/Application Support/Google/Chrome/Default/Bookmarks",
      "max_age_days": 30,
      "max_items": 25,
      "ignored_schemes": [
        "chrome",
        "javascript",
        "file"
      ]
    },
    "apple_reminders_inbox": {
      "enabled": false,
      "backend": "eventkit",
      "list": "Inbox",
      "max_items": 10
    },
    "apple_mail_summary": {
      "enabled": false,
      "backend": "local_summary_json",
      "messages_file": "samples/apple-mail-summary.json",
      "include_mailboxes": [
        "INBOX"
      ],
      "unread_only": true,
      "max_age_hours": 24,
      "max_items": 20
    }
  },
  "reminders": {
    "enabled": true,
    "domain_lists": {
      "money": "MONEY",
      "health": "HEALTH",
      "relationship": "NETWORK",
      "work": "WORK"
    }
  },
  "calendars": {
    "domain_calendars": {
      "money": "MONEY",
      "health": "HEALTH",
      "relationship": "FAMILY",
      "work": "WORK"
    }
  },
  "actions": {
    "auto_create_review_reminders": true,
    "auto_archive_low_value": true
  },
  "review": {
    "approval_keywords": [
      "批准",
      "同意",
      "approve",
      "approved"
    ]
  },
  "execution": {
    "auto_process_approved": false,
    "allowed_approved_actions": [
      "write_local_draft"
    ],
    "drafts_dir": "var/drafts"
  }
}
